# ================================================================
# EXTREME PRO UNITY 6 GAME DEV .GITIGNORE (2026)
# Used by professional studios shipping on Steam / consoles
# Always use with Git LFS + proper .gitattributes
# ================================================================

# Core Unity folders - NEVER commit these (they regenerate + are huge)
.utmp/
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/

# Huge generated data that can contain sensitive info
/[Mm]emoryCaptures/
[Rr]ecordings/

# Editor & IDE junk (keeps repo clean no matter what you use)
.vs/
.gradle/
.idea/
*.DotSettings.user
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
*.vsconfig

# Unity crash / debug files
sysinfo.txt
mono_crash.*
*.log

# Builds & packages (these belong in CI/CD or Releases tab)
*.apk
*.aab
*.unitypackage
*.app
*.buildreport

# Addressables (critical for pro games - these are rebuilt on every content build)
ServerData/
[Aa]ssets/StreamingAssets/aa*
[Aa]ssets/AddressableAssetsData/link.xml*
[Aa]ssets/Addressables_Temp*
[Aa]ssets/AddressableAssetsData/*/*.bin*

# Visual Scripting & Test Runner auto-generated
[Aa]ssets/Unity.VisualScripting.Generated/
[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*

# === PRO EXTRAS (Unity 6 + modern tools) ===
# Burst Compiler cache (can be 1GB+)
[Bb]urstCache/

# Code coverage reports (from Unity Test Runner)
CodeCoverage/

# UI Toolkit schema (auto-generated)
UIElementsSchema/

# Profiler sessions (can be massive)
*.profiler

# ParrelSync (most pro multiplayer devs use this for testing)
ParrelSync/
[Aa]ssets/ParrelSync/

# Crashlytics / analytics
crashlytics-build.properties

# Blender backup files (Unity handles .blend fine)
*.blend1
*.blend1.meta

# Optional: Asset Store Tools (uncomment if you use it)
# [Aa]ssets/AssetStoreTools*

# ================================================================
# CRITICAL SAFETY RULE - DO NOT REMOVE
# Unity .meta files MUST be committed or your project breaks
!/[Aa]ssets/**/*.meta
# ================================================================

# ================================================================
# FINAL NOTE FOR PROS
# This file is intentionally strict.
# Your actual game assets (.png, .fbx, .wav, .unity, .prefab etc.)
# should be tracked via Git LFS (see .gitattributes)
# ================================================================